{
  "_comment": "This file is generated. Please edit .homeycompose/app.json instead.",
  "id": "com.tts-on-demand",
  "version": "1.0.0",
  "compatibility": ">=12.3.0",
  "sdk": 3,
  "platforms": [
    "local"
  ],
  "runtime": "nodejs",
  "brandColor": "#4A90D9",
  "name": {
    "en": "TTS on Demand"
  },
  "description": {
    "en": "Send text-to-speech to Google Cast speakers from your dashboard"
  },
  "category": [
    "music"
  ],
  "tags": {
    "en": [
      "tts",
      "text-to-speech",
      "google",
      "cast",
      "chromecast",
      "nest",
      "speaker"
    ]
  },
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "permissions": [],
  "author": {
    "name": "sebcul"
  },
  "flow": {
    "actions": [
      {
        "title": {
          "en": "Say something on a Google Cast device"
        },
        "titleFormatted": {
          "en": "Say [[text]] on [[device]] in [[language]] at volume [[volume]] slow [[slow]]"
        },
        "hint": {
          "en": "Send a text-to-speech message to a Google Cast speaker"
        },
        "args": [
          {
            "type": "autocomplete",
            "name": "device",
            "title": {
              "en": "Device"
            },
            "placeholder": {
              "en": "Select a speaker..."
            }
          },
          {
            "type": "text",
            "name": "text",
            "title": {
              "en": "Text"
            },
            "placeholder": {
              "en": "What should I say?"
            }
          },
          {
            "type": "dropdown",
            "name": "language",
            "title": {
              "en": "Language"
            },
            "values": [
              {
                "id": "en",
                "label": {
                  "en": "English"
                }
              },
              {
                "id": "sv",
                "label": {
                  "en": "Swedish"
                }
              },
              {
                "id": "de",
                "label": {
                  "en": "German"
                }
              },
              {
                "id": "fr",
                "label": {
                  "en": "French"
                }
              },
              {
                "id": "es",
                "label": {
                  "en": "Spanish"
                }
              },
              {
                "id": "nl",
                "label": {
                  "en": "Dutch"
                }
              },
              {
                "id": "it",
                "label": {
                  "en": "Italian"
                }
              },
              {
                "id": "pt",
                "label": {
                  "en": "Portuguese"
                }
              },
              {
                "id": "da",
                "label": {
                  "en": "Danish"
                }
              },
              {
                "id": "no",
                "label": {
                  "en": "Norwegian"
                }
              },
              {
                "id": "fi",
                "label": {
                  "en": "Finnish"
                }
              },
              {
                "id": "pl",
                "label": {
                  "en": "Polish"
                }
              },
              {
                "id": "ja",
                "label": {
                  "en": "Japanese"
                }
              },
              {
                "id": "ko",
                "label": {
                  "en": "Korean"
                }
              },
              {
                "id": "zh-CN",
                "label": {
                  "en": "Chinese (Simplified)"
                }
              },
              {
                "id": "ru",
                "label": {
                  "en": "Russian"
                }
              },
              {
                "id": "ar",
                "label": {
                  "en": "Arabic"
                }
              },
              {
                "id": "hi",
                "label": {
                  "en": "Hindi"
                }
              }
            ]
          },
          {
            "type": "range",
            "name": "volume",
            "title": {
              "en": "Volume"
            },
            "min": 0,
            "max": 100,
            "step": 1,
            "value": 50,
            "label": "%",
            "labelDecimals": 0
          },
          {
            "type": "checkbox",
            "name": "slow",
            "title": {
              "en": "Slow speed"
            },
            "value": false
          }
        ],
        "id": "speak"
      }
    ]
  },
  "widgets": {
    "tts": {
      "name": {
        "en": "TTS on Demand"
      },
      "height": 200,
      "api": {
        "getDevices": {
          "method": "GET",
          "path": "/devices"
        },
        "getLanguages": {
          "method": "GET",
          "path": "/languages"
        },
        "speak": {
          "method": "POST",
          "path": "/speak"
        }
      },
      "id": "tts",
      "settings": []
    }
  },
  "discovery": {
    "googlecast": {
      "type": "mdns-sd",
      "mdns-sd": {
        "name": "googlecast",
        "protocol": "tcp"
      },
      "id": "{{txt.id}}"
    }
  }
}